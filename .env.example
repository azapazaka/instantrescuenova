APP_ENV=development

# ---------------------------------------------------------------- Database
# Local development / tests (default):
DATABASE_URL=sqlite:///./instant_rescue.db
#
# Supabase Postgres (production / demo). Get the password from
# Supabase Dashboard -> Project Settings -> Database -> Database password.
# Use the SESSION POOLER string and swap the driver to psycopg:
# DATABASE_URL=postgresql+psycopg://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres

# ------------------------------------------------------------------- Auth
# Supabase Dashboard -> Project Settings -> Data API
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=

# --------------------------------------------------------------------- AI
# Free key: https://console.groq.com/keys
# Leave empty to run in deterministic mock mode (no LLM calls).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_TOP_K=5

# -------------------------------------------------------------- Documents
MAX_PDF_UPLOAD_MB=20
MAX_PDF_PAGES=10

# ------------------------------------------------------------- Heart rate
# simulated = synthetic stream for demo; device = real hardware POSTs readings
HR_SOURCE=simulated
HR_SAMPLE_INTERVAL_SECONDS=5
HR_WINDOW_MINUTES=5

# --------------------------------------------------------------- Telegram
# Create a bot with @BotFather, then paste the token here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=InstantRescueBot
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_WEBHOOK_SECRET=

# ----------------------------------------------------------------- Safety
DEVICE_EVENT_COOLDOWN_SECONDS=60
ENABLE_DEMO_MODE=true
